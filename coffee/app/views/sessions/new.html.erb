<% content_for :title, "Sign in" %>
<% content_for :native_signals, native_form_tag %>

<div class="mt-8">
  <h1 class="text-2xl font-bold text-center text-coffee-800 dark:text-coffee-100">
    Welcome back
  </h1>
  <p class="mt-1 text-center text-sm text-coffee-500 dark:text-coffee-400">
    Sign in to your Daily Grind account
  </p>

  <%= form_with url: session_path, class: "mt-8 space-y-4" do |form| %>
    <div>
      <%= form.label :email, class: "block text-sm font-medium text-coffee-700 dark:text-coffee-300 mb-1" %>
      <%= form.email_field :email,
        autocomplete: "email",
        class: "w-full rounded-xl border border-coffee-200 dark:border-coffee-700 bg-white dark:bg-coffee-900 px-4 py-3 text-coffee-900 dark:text-coffee-100 placeholder-coffee-400 focus:outline-none focus:ring-2 focus:ring-coffee-500",
        placeholder: "you@example.com",
        value: "demo@example.com" %>
    </div>

    <div>
      <%= form.label :password, class: "block text-sm font-medium text-coffee-700 dark:text-coffee-300 mb-1" %>
      <%= form.password_field :password,
        autocomplete: "current-password",
        class: "w-full rounded-xl border border-coffee-200 dark:border-coffee-700 bg-white dark:bg-coffee-900 px-4 py-3 text-coffee-900 dark:text-coffee-100 placeholder-coffee-400 focus:outline-none focus:ring-2 focus:ring-coffee-500",
        value: "password" %>
    </div>

    <div>
      <%= form.submit "Sign in", class: "w-full rounded-xl bg-coffee-800 dark:bg-coffee-200 text-white dark:text-coffee-900 font-semibold py-3 hover:bg-coffee-700 dark:hover:bg-coffee-300 transition cursor-pointer" %>
    </div>
  <% end %>

  <div class="relative mt-8">
    <div class="absolute inset-0 flex items-center">
      <div class="w-full border-t border-coffee-200 dark:border-coffee-700"></div>
    </div>
    <div class="relative flex justify-center text-sm">
      <span class="bg-cream dark:bg-cream-dark px-4 text-coffee-400 dark:text-coffee-500">or</span>
    </div>
  </div>

  <div class="mt-6 space-y-3">
    <%= button_to "/auth/google_oauth2", data: { turbo: false }, class: "w-full rounded-xl border border-coffee-300 dark:border-coffee-600 text-coffee-700 dark:text-coffee-300 font-semibold py-3 hover:bg-coffee-50 dark:hover:bg-coffee-900 transition cursor-pointer" do %>
      Sign in with Google
    <% end %>

    <%= button_to "/auth/apple", data: { turbo: false }, class: "w-full rounded-xl bg-black dark:bg-white text-white dark:text-black font-semibold py-3 hover:bg-gray-800 dark:hover:bg-gray-200 transition cursor-pointer" do %>
      Sign in with Apple
    <% end %>
  </div>

  <%= button_to "Continue as guest", guest_session_path, class: "w-full mt-3 rounded-xl border border-coffee-300 dark:border-coffee-600 text-coffee-700 dark:text-coffee-300 font-semibold py-3 hover:bg-coffee-50 dark:hover:bg-coffee-900 transition cursor-pointer" %>

  <p class="text-center mt-6 text-sm text-coffee-500 dark:text-coffee-400">
    Don't have an account?
    <%= link_to "Create one", new_registration_path, class: "font-medium text-coffee-800 dark:text-coffee-200 underline" %>
  </p>
</div>
