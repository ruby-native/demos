source "https://rubygems.org"

gem "rails", "~> 8.1.2"

gem "bcrypt", "~> 3.1.7"
gem "bootsnap", require: false
gem "propshaft"
gem "puma", ">= 5.0"
gem "sqlite3", ">= 2.1"
gem "tzinfo-data", platforms: %i[windows jruby]

# Hotwire frontend.
gem "importmap-rails"
gem "stimulus-rails"
gem "turbo-rails"
gem "tailwindcss-rails"

# Native bridge.
gem_path = File.expand_path("../../gem", __dir__)
if File.exist?(gem_path)
  gem "ruby_native", path: gem_path
else
  gem "ruby_native"
end

# OAuth.
gem "omniauth"
gem "omniauth-google-oauth2"
gem "omniauth-apple"
gem "omniauth-rails_csrf_protection"

# Background jobs and WebSockets.
gem "solid_queue"
gem "solid_cable"

# Push notifications.
gem "action_push_native"

group :development do
  gem "web-console"
end
