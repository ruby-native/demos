<% content_for :title, @book.title %>

<%= native_navbar_tag do |navbar| %>
  <% navbar.button "More", icons: { ios: "ellipsis.circle", android: "more_vert" } do |menu| %>
    <% if @book.currently_reading? %>
      <% menu.item "Update progress", href: edit_progress_book_path(@book), icons: { ios: "book", android: "menu_book" } %>
    <% end %>
    <% if @book.want_to_read? %>
      <% menu.item "Start reading", click: "#status-reading", icons: { ios: "book", android: "menu_book" } %>
    <% end %>
    <% unless @book.finished? %>
      <% menu.item "Mark as finished", click: "#status-finished", icons: { ios: "checkmark.circle", android: "check_circle" } %>
    <% end %>
    <% if @book.finished? %>
      <% menu.item "Move back to reading", click: "#status-reading", icons: { ios: "book", android: "menu_book" } %>
    <% end %>
    <% unless @book.want_to_read? %>
      <% menu.item "Move to want to read", click: "#status-want", icons: { ios: "bookmark", android: "bookmark" } %>
    <% end %>
    <% menu.item "Delete", click: "#delete-book", icons: { ios: "trash", android: "delete" } %>
  <% end %>
  <% navbar.share_button %>
<% end %>

<% if flash[:celebrate] %>
  <div class="mx-5 mt-5 rounded-2xl bg-emerald-50 ring-1 ring-emerald-200 p-5 text-center">
    <p class="font-display text-xl font-semibold text-emerald-900 text-balance">You finished <%= flash[:celebrate] %></p>
    <p class="mt-1 text-[0.9375rem] text-emerald-700">That's one more for your year.</p>
  </div>
  <%= native_review_tag %>
<% end %>

<%
  status_styles =
    case @book.status
    when "currently_reading" then { ring: "ring-accent-200",  bg: "bg-accent-50",  fg: "text-accent-800" }
    when "finished"          then { ring: "ring-emerald-200", bg: "bg-emerald-50", fg: "text-emerald-800" }
    else                          { ring: "ring-stone-200",   bg: "bg-stone-100",  fg: "text-stone-700" }
    end
  status_icon =
    case @book.status
    when "currently_reading" then '<path fill-rule="evenodd" d="M10 2c-2.4-.9-5.3-1.4-7.5-1.4A.75.75 0 0 0 1.75 1.4v12.5c0 .4.3.7.7.75 2 .05 4.8.5 7.05 1.3a1.6 1.6 0 0 0 1 0c2.25-.8 5.05-1.25 7.05-1.3a.75.75 0 0 0 .7-.75V1.4a.75.75 0 0 0-.75-.8c-2.2 0-5.1.5-7.5 1.4Z" clip-rule="evenodd"/>'
    when "finished"          then '<path fill-rule="evenodd" d="M10 18a8 8 0 1 0 0-16 8 8 0 0 0 0 16Zm3.85-10.85a.75.75 0 0 0-1.2-.9l-3.65 4.86-1.69-1.7a.75.75 0 0 0-1.06 1.07l2.3 2.3a.75.75 0 0 0 1.13-.09l4.17-5.54Z" clip-rule="evenodd"/>'
    else                          '<path fill-rule="evenodd" d="M5 4a2 2 0 0 1 2-2h6a2 2 0 0 1 2 2v13.6a.5.5 0 0 1-.74.43L10 15.42l-4.26 2.61A.5.5 0 0 1 5 17.6V4Z" clip-rule="evenodd"/>'
    end
%>

<section class="px-5 pt-6">
  <%= render "books/cover", book: @book, size: :lg %>

  <h1 class="font-display text-[1.875rem]/[1.1] font-semibold tracking-tight text-center mt-7 text-balance text-stone-900"><%= @book.title %></h1>
  <p class="text-[1.0625rem] text-stone-500 text-center mt-2"><%= @book.author %></p>

  <div class="mt-5 flex justify-center">
    <span class="inline-flex items-center gap-1.5 rounded-full <%= status_styles[:bg] %> ring-1 <%= status_styles[:ring] %> px-3.5 py-1.5 text-[0.9375rem] font-semibold <%= status_styles[:fg] %>">
      <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" class="size-4"><%== status_icon %></svg>
      <%= @book.status_label %>
    </span>
  </div>
</section>

<% if @book.currently_reading? && @book.pages.to_i > 0 %>
  <% pct = [(@book.current_page.to_f / @book.pages * 100).round, 100].min %>
  <section class="px-5 mt-8">
    <div class="rounded-2xl bg-white ring-1 ring-stone-950/5 p-5">
      <div class="flex items-baseline justify-between gap-3">
        <p class="font-display text-2xl font-semibold tabular-nums text-stone-900">Page <%= @book.current_page %></p>
        <p class="text-[0.9375rem] text-stone-500 tabular-nums">of <%= @book.pages %></p>
      </div>
      <div class="mt-3 h-2 rounded-full bg-stone-200 overflow-hidden">
        <div class="h-full rounded-full bg-accent-600 w-(--progress)" style="--progress: <%= pct %>%"></div>
      </div>
      <p class="mt-2 text-[0.8125rem] font-medium text-stone-500 tabular-nums"><%= pct %>% complete</p>
      <%= link_to "Update progress", edit_progress_book_path(@book),
            class: "mt-4 block w-full rounded-xl bg-accent-600 text-white text-center text-[0.9375rem] font-medium py-2.5 active:scale-[0.99] transition" %>
    </div>
  </section>
<% end %>

<%
  stats = []
  stats << ["Started",  @book.started_at.to_date.strftime("%b %-d, %Y")]   if @book.started_at.present?
  stats << ["Finished", @book.finished_at.to_date.strftime("%b %-d, %Y")] if @book.finished_at.present?
  stats << ["Pages",    @book.pages]                                       if @book.pages.to_i > 0
  stats << ["ISBN",     @book.isbn]                                        if @book.isbn.present?
%>
<% if stats.any? %>
  <section class="mt-8">
    <%= render "shared/section_label", text: "Details" %>
    <dl class="mx-5 grid grid-cols-2 rounded-2xl bg-white ring-1 ring-stone-950/5 divide-x divide-y divide-stone-950/5 [&>div:nth-child(-n+2)]:border-t-0 [&>div:nth-child(2n+1)]:border-l-0">
      <% stats.each do |label, value| %>
        <div class="p-4">
          <dt class="text-[0.75rem] font-semibold tracking-wider uppercase text-stone-500"><%= label %></dt>
          <dd class="mt-1.5 text-[0.9375rem] font-medium text-stone-900 tabular-nums"><%= value %></dd>
        </div>
      <% end %>
    </dl>
  </section>
<% end %>

<%#
  Web fallback for the navbar overflow menu at the top of the page. In the app
  the native menu drives these actions through its click: selectors; on the web
  they are ordinary buttons. native-hidden keeps them out of the app, so the
  menu stays the only copy the user sees there. The haptics live on the buttons
  themselves, so they fire whether tapped on the web or clicked by the menu.
%>
<section class="px-5 mt-8 native-hidden">
  <%
    action = "block w-full rounded-2xl bg-white ring-1 ring-stone-950/5 py-3.5 text-center text-[0.9375rem] font-semibold text-stone-800 active:bg-stone-50 transition cursor-pointer"
    danger = action.sub("text-stone-800", "text-red-600")
  %>
  <div class="space-y-2">
    <% if @book.want_to_read? %>
      <%= button_to "Start reading", change_status_book_path(@book, status: "currently_reading"), method: :patch, id: "status-reading", class: action %>
    <% end %>
    <% unless @book.finished? %>
      <%= button_to "Mark as finished", change_status_book_path(@book, status: "finished"), method: :patch, id: "status-finished", data: native_haptic_data(:success), class: action %>
    <% end %>
    <% if @book.finished? %>
      <%= button_to "Move back to reading", change_status_book_path(@book, status: "currently_reading"), method: :patch, id: "status-reading", class: action %>
    <% end %>
    <% unless @book.want_to_read? %>
      <%= button_to "Move to want to read", change_status_book_path(@book, status: "want_to_read"), method: :patch, id: "status-want", class: action %>
    <% end %>
    <%= button_to "Delete", book_path(@book), method: :delete, id: "delete-book",
          data: native_haptic_data(:warning, turbo_confirm: "Remove #{@book.title} from your shelf?"), class: danger %>
  </div>
</section>
