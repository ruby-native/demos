<% content_for :title, "Add book" %>

<%= native_form_tag %>

<%= native_navbar_tag "Add book" do |navbar| %>
  <% navbar.submit_button title: "Save" %>
<% end %>

<%
  field = "block w-full rounded-xl bg-white px-3.5 py-3 text-base ring-1 ring-stone-950/10 placeholder:text-stone-400 focus:outline-2 focus:outline-accent-600 -outline-offset-1 transition"
  label = "block text-[0.8125rem] font-medium text-stone-700 mb-1.5"
%>

<%= form_with model: @book, class: "px-5 pt-6 space-y-5" do |f| %>
  <% if @book.errors.any? %>
    <div class="rounded-xl bg-red-50 text-red-900 ring-1 ring-red-200 px-4 py-3 text-[0.9375rem]">
      <%= @book.errors.full_messages.to_sentence %>
    </div>
  <% end %>

  <div>
    <%= f.label :title, class: label %>
    <%= f.text_field :title, required: true, class: field %>
  </div>
  <div>
    <%= f.label :author, class: label %>
    <%= f.text_field :author, required: true, class: field %>
  </div>
  <div class="grid grid-cols-2 gap-3">
    <div>
      <%= f.label :pages, "Pages", class: label %>
      <%= f.number_field :pages, min: 1, class: field %>
    </div>
    <div>
      <%= f.label :status, "Shelf", class: label %>
      <%= f.select :status, [["Want to read", "want_to_read"], ["Currently reading", "currently_reading"]], {}, class: field %>
    </div>
  </div>
  <div>
    <%= f.label :isbn, "ISBN", class: label %>
    <%= f.text_field :isbn, class: field %>
  </div>
  <div>
    <%= f.label :cover, "Cover image", class: label %>
    <%= f.file_field :cover, accept: "image/*",
          class: "block w-full rounded-xl bg-white px-3.5 py-3 text-[0.9375rem] ring-1 ring-stone-950/10 file:mr-3 file:rounded-md file:border-0 file:bg-stone-100 file:px-3 file:py-1.5 file:text-stone-700 file:font-medium file:text-[0.8125rem] file:cursor-pointer" %>
  </div>

  <%= f.submit "Save", data: native_haptic_data(:success),
        class: "native-hidden mt-2 w-full rounded-xl bg-accent-600 hover:bg-accent-700 text-white text-[0.9375rem] font-medium py-3.5 active:scale-[0.99] transition cursor-pointer focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent-600" %>
<% end %>
