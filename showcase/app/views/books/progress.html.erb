<% content_for :title, "Update progress" %>

<%= native_form_tag %>

<%= native_navbar_tag "Update progress" do |navbar| %>
  <% navbar.submit_button title: "Save" %>
<% end %>

<% field = "block w-full rounded-xl bg-white px-3.5 py-3 text-base ring-1 ring-stone-950/10 focus:outline-2 focus:outline-accent-600 -outline-offset-1 transition" %>

<section class="px-5 pt-6">
  <div class="flex items-center gap-4">
    <%= render "books/cover", book: @book, size: :sm %>
    <div class="min-w-0">
      <p class="font-display text-lg font-semibold leading-snug text-stone-900 line-clamp-2"><%= @book.title %></p>
      <p class="text-[0.9375rem] text-stone-500 truncate mt-0.5"><%= @book.author %></p>
    </div>
  </div>
</section>

<%= form_with model: @book, url: progress_book_path(@book), method: :patch, class: "px-5" do |f| %>
  <% if @book.pages.to_i > 0 %>
    <div data-controller="progress" class="pt-10">
      <div class="text-center">
        <p class="font-display text-6xl/none font-semibold tabular-nums text-stone-900" data-progress-target="display"><%= @book.current_page %></p>
        <p class="mt-2 text-[0.9375rem] text-stone-500 tabular-nums">of <%= @book.pages %> pages</p>
      </div>

      <input type="range" min="0" max="<%= @book.pages %>" value="<%= @book.current_page %>"
             data-progress-target="slider" data-action="input->progress#sync" aria-label="Current page"
             class="mt-8 w-full accent-accent-600">

      <div class="mt-6 flex justify-center gap-2">
        <% [10, 25, 50].each do |amount| %>
          <button type="button" data-action="progress#add" data-progress-amount-param="<%= amount %>" data-native-haptic="selection"
                  class="rounded-full bg-white ring-1 ring-stone-950/10 px-4 py-2 text-[0.9375rem] font-medium text-stone-700 active:bg-stone-50 transition">
            +<%= amount %>
          </button>
        <% end %>
      </div>

      <div class="mt-8">
        <%= f.label :current_page, "Current page", class: "block text-[0.8125rem] font-medium text-stone-700 mb-1.5" %>
        <%= f.number_field :current_page, min: 0, max: @book.pages,
              data: { progress_target: "input", action: "input->progress#sync" }, class: field %>
      </div>
    </div>
  <% else %>
    <div class="pt-8">
      <%= f.label :current_page, "Current page", class: "block text-[0.8125rem] font-medium text-stone-700 mb-1.5" %>
      <%= f.number_field :current_page, min: 0, class: field %>
    </div>
  <% end %>

  <%= f.submit "Save", data: native_haptic_data(:success),
        class: "native-hidden mt-8 w-full rounded-xl bg-accent-600 hover:bg-accent-700 text-white text-[0.9375rem] font-medium py-3.5 active:scale-[0.99] transition cursor-pointer" %>
<% end %>
