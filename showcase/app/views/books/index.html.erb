<%
  filter_labels = { "currently_reading" => "Currently reading", "want_to_read" => "Want to read", "finished" => "Finished" }
%>
<% content_for :title, @filter ? filter_labels[@filter] : "Library" %>

<% if @filter.nil? %>
  <%= native_navbar_tag do |navbar| %>
    <% navbar.button "Filter", icons: { ios: "line.3.horizontal.decrease", android: "filter_list" }, position: "leading" do |menu| %>
      <% menu.item "Currently reading", href: root_path(filter: "currently_reading"), icons: { ios: "book",             android: "menu_book" } %>
      <% menu.item "Want to read",      href: root_path(filter: "want_to_read"),      icons: { ios: "bookmark",         android: "bookmark" } %>
      <% menu.item "Finished",          href: root_path(filter: "finished"),          icons: { ios: "checkmark.circle", android: "check_circle" } %>
    <% end %>
  <% end %>
<% end %>

<%= native_fab_tag icons: { ios: "plus", android: "add" }, href: new_book_path %>

<% if @filter.nil? && @currently_reading.any? %>
  <section class="pt-6">
    <%= render "shared/section_label", text: "Currently reading" %>
    <ul role="list" class="px-5 space-y-3">
      <% @currently_reading.each do |book| %>
        <li>
          <%= link_to book, class: "flex gap-4 p-3.5 rounded-2xl bg-white ring-1 ring-stone-950/5 active:bg-stone-50 transition-colors" do %>
            <%= render "books/cover", book: book, size: :sm %>
            <div class="flex-1 min-w-0 self-center">
              <p class="font-display text-lg font-semibold leading-snug truncate text-stone-900"><%= book.title %></p>
              <p class="text-[0.9375rem] text-stone-500 truncate mt-0.5"><%= book.author %></p>
              <% if book.pages && book.pages.to_i > 0 %>
                <% pct = [(book.current_page.to_f / book.pages * 100).round, 100].min %>
                <div class="mt-3 h-1.5 rounded-full bg-stone-200 overflow-hidden">
                  <div class="h-full rounded-full bg-accent-600 w-(--progress)" style="--progress: <%= pct %>%"></div>
                </div>
                <p class="text-[0.8125rem] text-stone-500 mt-2 tabular-nums"><%= book.current_page %> of <%= book.pages %> pages, <%= pct %>%</p>
              <% end %>
            </div>
          <% end %>
        </li>
      <% end %>
    </ul>
  </section>
<% end %>

<section class="<%= @filter ? 'pt-6' : 'mt-10' %>">
  <% unless @filter %>
    <%= render "shared/section_label", text: "Your shelf" %>
  <% end %>
  <ul role="list" class="px-5 grid grid-cols-3 gap-x-4 gap-y-7">
    <% @books.each do |book| %>
      <li>
        <%= link_to book, class: "block active:opacity-80 transition-opacity" do %>
          <%= render "books/cover", book: book, size: :grid %>
          <p class="mt-2.5 text-[0.9375rem] font-semibold leading-snug text-stone-900 line-clamp-1"><%= book.title %></p>
          <p class="text-[0.8125rem] text-stone-500 leading-tight truncate mt-0.5"><%= book.author %></p>
        <% end %>
      </li>
    <% end %>
  </ul>
</section>
