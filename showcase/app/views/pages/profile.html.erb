<% content_for :title, "Profile" %>

<div class="px-5 pt-6">
  <div class="flex items-center gap-4 p-4 rounded-2xl bg-white ring-1 ring-stone-950/5">
    <div class="size-14 rounded-full bg-accent-100 flex items-center justify-center font-display text-2xl font-semibold text-accent-800" aria-hidden="true">
      <%= @user.email_address.first.upcase %>
    </div>
    <div class="flex-1 min-w-0">
      <p class="text-[0.8125rem] text-stone-500">Signed in as</p>
      <p class="text-[0.9375rem] font-medium text-stone-900 truncate"><%= @user.email_address %></p>
    </div>
  </div>
</div>

<section class="mt-8">
  <%= render "shared/section_label", text: "Account" %>
  <div class="mx-5">
    <%= button_to session_path,
          method: :delete,
          form: { class: "block" },
          class: "w-full rounded-2xl bg-white ring-1 ring-stone-950/5 py-4 px-4 text-[0.9375rem] font-semibold text-red-600 active:bg-stone-50 transition-colors cursor-pointer",
          data: { turbo_confirm: "Sign out of Shelf?" } do %>
      Sign out
    <% end %>
    <p class="mt-4 text-center text-[0.8125rem] text-stone-400">Shelf 1.0</p>
  </div>
</section>
