<% content_for :title, "Add note" %>

<%= form_with model: [@book, @note], class: "px-5 pt-6 space-y-5" do |f| %>
  <% if @note.errors.any? %>
    <div class="rounded-xl bg-red-50 text-red-900 ring-1 ring-red-200 px-4 py-3 text-[0.9375rem]">
      <%= @note.errors.full_messages.to_sentence %>
    </div>
  <% end %>

  <div>
    <p class="text-[0.8125rem] text-stone-500">Note on</p>
    <p class="font-display text-lg font-semibold text-stone-900"><%= @book.title %></p>
  </div>

  <div>
    <%= f.label :body, "Your note", class: "block text-[0.8125rem] font-medium text-stone-700 mb-1.5" %>
    <%= f.text_area :body, rows: 6, required: true,
          class: "block w-full rounded-xl bg-white px-3.5 py-3 text-base ring-1 ring-stone-950/10 placeholder:text-stone-400 focus:outline-2 focus:outline-accent-600 -outline-offset-1 transition" %>
  </div>

  <%= f.submit "Save note",
        class: "mt-2 w-full rounded-xl bg-accent-600 hover:bg-accent-700 text-white text-[0.9375rem] font-medium py-3.5 active:scale-[0.99] transition cursor-pointer focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent-600" %>
<% end %>
