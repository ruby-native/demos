<!DOCTYPE html>
<html class="h-full">
  <head>
    <title><%= @hide_title ? "" : (content_for(:title) || "Shelf") %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1,viewport-fit=cover">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Shelf">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag :ruby_native %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="min-h-dvh bg-surface text-stone-900 font-sans antialiased">
    <%= native_tabs_tag(enabled: authenticated?) %>

    <main class="native-inset pb-10">
      <%= render "shared/flash" %>
      <%= yield %>
    </main>
  </body>
</html>
