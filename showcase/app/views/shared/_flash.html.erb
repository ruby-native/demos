<%# Renders the conventional message flashes. Data flashes like :celebrate are %>
<%# read explicitly where they are shown, so they are not styled as banners. %>
<% { notice: "bg-accent-50 text-accent-900 ring-accent-200", alert: "bg-red-50 text-red-900 ring-red-200" }.each do |key, styles| %>
  <% if flash[key].present? %>
    <div class="mx-5 mt-4 rounded-xl px-4 py-3 text-[0.9375rem] font-medium ring-1 <%= styles %>">
      <%= flash[key] %>
    </div>
  <% end %>
<% end %>
