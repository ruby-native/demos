<% content_for :title, @brewery.name %>

<%# Hero photo %>
<% if @brewery.photo.attached? %>
  <div class="-mx-4 sm:mx-0 -mt-4">
    <%= image_tag @brewery.photo.variant(resize_to_fill: [800, 320, { crop: :attention }]),
      class: "w-full h-48 object-cover sm:rounded-b-lg",
      alt: @brewery.name %>
  </div>
<% end %>

<div class="space-y-5 <%= @brewery.photo.attached? ? "mt-5" : "mt-4" %>">
  <%# Header with stamp + bookmark %>
  <div>
    <% unless native_app? %>
      <h1 class="text-2xl font-bold"><%= @brewery.name %></h1>
    <% end %>
    <p class="text-sm text-stone-500 dark:text-stone-400 mt-1">
      <%= @brewery.brewery_type.capitalize %> brewery<%= " in #{link_to @brewery.neighborhood.name, neighborhood_path(@brewery.neighborhood), class: 'text-stone-600 dark:text-stone-300 underline decoration-stone-300 dark:decoration-stone-600 underline-offset-2'}".html_safe if @brewery.neighborhood.present? %>
    </p>
    <% if user_signed_in? %>
      <div class="flex items-center gap-3 mt-3">
        <%= render "stamps/button", brewery: @brewery, stamp: @stamp %>
        <%= render "bookmarks/button", brewery: @brewery, bookmarked: @bookmark %>
      </div>
    <% elsif !native_app? %>
      <p class="text-sm text-stone-500 dark:text-stone-400 mt-2">
        <%= link_to "Sign in", new_session_path, class: "font-medium text-brew-700 dark:text-brew-400 underline" %> to track your visits.
      </p>
    <% end %>
  </div>

  <%# Feature icons %>
  <% features = [] %>
  <% features << { icon: "sun", label: "Outdoor seating" } if @brewery.outdoor_seating %>
  <% features << { icon: "dog", label: "Dog friendly" } if @brewery.dog_friendly %>
  <% features << { icon: "kid", label: "Kid friendly" } if @brewery.kid_friendly %>
  <% features << { icon: "wifi", label: "WiFi" } if @brewery.wifi %>
  <% if features.any? %>
    <div class="scroll-fade -mr-4 sm:mr-0">
    <div class="flex gap-4 overflow-x-auto pr-8 sm:pr-0 scrollbar-none">
      <% features.each do |feature| %>
        <div class="flex items-center gap-1.5 text-xs whitespace-nowrap text-brew-700 dark:text-brew-300" title="<%= feature[:label] %>">
          <% case feature[:icon] %>
          <% when "sun" %>
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z" />
            </svg>
          <% when "dog" %>
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.182 15.182a4.5 4.5 0 0 1-6.364 0M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0ZM9.75 9.75c0 .414-.168.75-.375.75S9 10.164 9 9.75 9.168 9 9.375 9s.375.336.375.75Zm-.375 0h.008v.015h-.008V9.75Zm5.625 0c0 .414-.168.75-.375.75s-.375-.336-.375-.75.168-.75.375-.75.375.336.375.75Zm-.375 0h.008v.015h-.008V9.75Z" />
            </svg>
          <% when "kid" %>
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z" />
            </svg>
          <% when "wifi" %>
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8.288 15.038a5.25 5.25 0 0 1 7.424 0M5.106 11.856c3.807-3.808 9.98-3.808 13.788 0M1.924 8.674c5.565-5.565 14.587-5.565 20.152 0M12.53 18.22l-.53.53-.53-.53a.75.75 0 0 1 1.06 0Z" />
            </svg>
          <% end %>
          <%= feature[:label] %>
        </div>
      <% end %>
    </div>
    </div>
  <% end %>

  <%# Hours %>
  <% if @brewery.hours.present? %>
    <div class="-mx-4 sm:mx-0 sm:rounded-lg bg-white dark:bg-stone-900 sm:shadow-sm px-4 sm:p-4 py-3">
      <div class="flex items-start gap-3">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-brew-600 dark:text-brew-400 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
        </svg>
        <div class="text-sm font-mono">
          <% @brewery.hours.split(",").each do |chunk| %>
            <% parts = chunk.strip.rpartition(" ") %>
            <p class="text-stone-800 dark:text-stone-200">
              <span class="font-semibold"><%= parts.first %></span> <%= parts.last %>
            </p>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>

  <%# Map + address card %>
  <% maps_link = "https://maps.apple.com/?q=#{CGI.escape(@brewery.name)}&ll=#{@brewery.latitude},#{@brewery.longitude}" %>
  <% has_map = @brewery.map_light.attached? %>
  <% if has_map || @brewery.street.present? %>
    <%= link_to maps_link, target: "_blank", rel: "noopener", class: "block -mx-4 sm:mx-0 sm:rounded-lg bg-white dark:bg-stone-900 sm:shadow-sm overflow-hidden no-underline" do %>
      <% if has_map %>
        <%= image_tag @brewery.map_mobile_light.attached? ? @brewery.map_mobile_light : @brewery.map_light, class: "w-full sm:hidden dark:hidden", alt: "Map of #{@brewery.name}", loading: "lazy" %>
        <%= image_tag @brewery.map_mobile_dark.attached? ? @brewery.map_mobile_dark : @brewery.map_dark, class: "w-full sm:hidden hidden dark:block", alt: "Map of #{@brewery.name}", loading: "lazy" %>
        <%= image_tag @brewery.map_light, class: "w-full hidden sm:block dark:sm:hidden", alt: "Map of #{@brewery.name}", loading: "lazy" %>
        <%= image_tag @brewery.map_dark, class: "w-full hidden dark:sm:block", alt: "Map of #{@brewery.name}", loading: "lazy" %>
      <% end %>
      <% if @brewery.street.present? %>
        <div class="flex items-start gap-3 px-4 sm:p-4 py-3">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-brew-600 dark:text-brew-400 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
          </svg>
          <div>
            <p class="font-medium text-stone-800 dark:text-stone-200"><%= @brewery.street %></p>
            <p class="text-sm text-stone-500 dark:text-stone-400"><%= @brewery.city %>, <%= @brewery.state %> <%= @brewery.postal_code %></p>
          </div>
        </div>
      <% end %>
    <% end %>
  <% end %>

  <%# Contact card %>
  <% if @brewery.phone.present? || @brewery.website_url.present? %>
    <div class="-mx-4 sm:mx-0 sm:rounded-lg bg-white dark:bg-stone-900 sm:shadow-sm divide-y divide-stone-100 dark:divide-stone-800">
      <% if @brewery.phone.present? %>
        <%= link_to "tel:#{@brewery.phone}", class: "flex items-center gap-3 px-4 sm:p-4 py-3 text-sm font-medium text-stone-800 dark:text-stone-200 no-underline" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-brew-600 dark:text-brew-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" />
          </svg>
          <%= @brewery.formatted_phone %>
        <% end %>
      <% end %>

      <% if @brewery.website_url.present? %>
        <%= link_to @brewery.website_url, target: "_blank", rel: "noopener", class: "flex items-center gap-3 px-4 sm:p-4 py-3 text-sm font-medium text-stone-800 dark:text-stone-200 no-underline" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-brew-600 dark:text-brew-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 0 0 8.716-6.747M12 21a9.004 9.004 0 0 1-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 0 1 7.843 4.582M12 3a8.997 8.997 0 0 0-7.843 4.582m15.686 0A11.953 11.953 0 0 1 12 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0 1 21 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0 1 12 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 0 1 3 12c0-1.605.42-3.113 1.157-4.418" />
          </svg>
          Visit website
        <% end %>
      <% end %>
    </div>
  <% end %>
</div>
