<%= link_to brewery_path(brewery), class: "block rounded-2xl bg-white dark:bg-stone-900 shadow-sm no-underline overflow-hidden" do %>
  <% if brewery.photo.attached? %>
    <%= image_tag brewery.photo.variant(resize_to_fill: [800, 320, { crop: :attention }]),
      class: "w-full h-44 object-cover bg-stone-100 dark:bg-stone-800 shimmer",
      alt: brewery.name %>
  <% end %>
  <div class="flex items-center justify-between p-4">
    <div class="min-w-0">
      <h2 class="font-semibold"><%= brewery.name %></h2>
      <p class="text-sm text-stone-500 dark:text-stone-400 mt-0.5"><%= brewery.street %></p>
    </div>
    <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-stone-400 dark:text-stone-600 shrink-0 ml-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
    </svg>
  </div>
<% end %>
