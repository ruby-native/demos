<% content_for :title, "Passport progress" %>

<div class="mt-4">
  <% unless native_app? %>
    <h1 class="text-2xl font-bold">Passport progress</h1>
  <% end %>

  <div class="mt-4 p-4 rounded-2xl bg-white dark:bg-stone-900 shadow-sm">
    <p class="text-3xl font-bold">
      <%= @total_stamped %> <span class="text-base font-normal text-stone-500 dark:text-stone-400">of <%= @total_breweries %></span>
    </p>
    <div class="mt-2 h-2 rounded-full bg-stone-200 dark:bg-stone-800 overflow-hidden">
      <% percentage = @total_breweries > 0 ? (@total_stamped.to_f / @total_breweries * 100).round : 0 %>
      <div class="h-full rounded-full bg-brew-600 dark:bg-brew-400 transition-all" style="width: <%= percentage %>%"></div>
    </div>
  </div>

  <div class="mt-6 space-y-3">
    <% @neighborhoods.each do |entry| %>
      <%= link_to neighborhood_path(entry.neighborhood), class: "block p-4 rounded-2xl bg-white dark:bg-stone-900 shadow-sm no-underline" do %>
        <div class="flex items-center justify-between">
          <div class="min-w-0 flex-1">
            <div class="flex items-center gap-2">
              <h2 class="font-semibold"><%= entry.neighborhood.name %></h2>
              <% if entry.complete %>
                <span class="text-xs font-medium text-brew-700 dark:text-brew-400 bg-brew-50 dark:bg-brew-950 px-2 py-0.5 rounded-full">Complete</span>
              <% end %>
            </div>
            <p class="text-sm text-stone-500 dark:text-stone-400 mt-0.5">
              <%= entry.stamped %> of <%= entry.total %> <%= "brewery".pluralize(entry.total) %>
            </p>
          </div>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-stone-400 dark:text-stone-600 shrink-0 ml-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
          </svg>
        </div>
        <div class="mt-2 h-2 rounded-full bg-stone-200 dark:bg-stone-800 overflow-hidden">
          <div class="h-full rounded-full bg-brew-600 dark:bg-brew-400 transition-all" style="width: <%= entry.percentage %>%"></div>
        </div>
      <% end %>
    <% end %>
  </div>
</div>
