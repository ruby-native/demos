<% content_for :title, "Profile" %>

<div class="mt-4">
  <% unless native_app? %>
    <h1 class="text-2xl font-bold">Profile</h1>
  <% end %>

  <%= native_navbar_tag do |navbar| %>
    <% navbar.button "Menu", icons: { ios: "line.3.horizontal", android: "menu" }, position: "leading" do |menu| %>
      <% menu.item "Sign out", click: "#sign-out-button" %>
      <% menu.item "Delete account", click: "#delete-account-button" %>
    <% end %>
    <% navbar.button "Edit", icons: { ios: "pencil", android: "edit" }, href: edit_profile_path %>
  <% end %>

  <div class="mt-4 p-4 rounded-2xl bg-white dark:bg-stone-900 shadow-sm">
    <p class="font-semibold"><%= current_user.name || "Beervana user" %></p>
    <% if current_user.email.present? %>
      <p class="text-sm text-stone-500 dark:text-stone-400 mt-0.5"><%= current_user.email %></p>
    <% end %>
  </div>

  <div class="mt-4 p-4 rounded-2xl bg-white dark:bg-stone-900 shadow-sm">
    <div class="flex justify-between">
      <div class="text-center flex-1">
        <p class="text-2xl font-bold"><%= @stamp_count %></p>
        <p class="text-xs text-stone-500 dark:text-stone-400 mt-0.5">Stamped</p>
      </div>
      <div class="text-center flex-1 border-l border-stone-200 dark:border-stone-800">
        <p class="text-2xl font-bold"><%= @bookmark_count %></p>
        <p class="text-xs text-stone-500 dark:text-stone-400 mt-0.5">Want to go</p>
      </div>
    </div>
  </div>

  <div class="mt-6 space-y-3 native-hidden">
    <%= link_to "Edit profile", edit_profile_path, class: "block w-full p-4 rounded-2xl bg-white dark:bg-stone-900 shadow-sm text-left font-medium text-stone-900 dark:text-stone-100" %>
    <%= button_to "Sign out", session_path, id: "sign-out-button", method: :delete, class: "w-full p-4 rounded-2xl bg-white dark:bg-stone-900 shadow-sm text-left font-medium text-red-600 dark:text-red-400 cursor-pointer" %>
    <%= button_to "Delete account", profile_path, id: "delete-account-button", method: :delete, class: "w-full p-4 rounded-2xl bg-white dark:bg-stone-900 shadow-sm text-left font-medium text-red-600 dark:text-red-400 cursor-pointer", data: { turbo_confirm: "This will permanently delete your account and all your stamps and bookmarks. Are you sure?" } %>
  </div>

  <div class="mt-8 text-center">
    <p class="text-xs text-stone-400 dark:text-stone-600">
      Brewery data from
      <%= link_to "Open Brewery DB", "https://www.openbrewerydb.org", target: "_blank", rel: "noopener", class: "underline" %>.
      Licensed under MIT.
    </p>
  </div>
</div>
