<% content_for :title, "Beervana - Your Portland brewery passport" %>
<% content_for :nav_title, "Beervana" %>

<div class="mt-12 text-center">
  <%= image_tag "logo.png", class: "w-24 h-24 rounded-2xl mx-auto shadow-md", alt: "Beervana" %>

  <h1 class="mt-6 text-4xl font-bold">Beervana</h1>
  <p class="mt-3 text-lg text-stone-500 dark:text-stone-400">Your Portland brewery passport.</p>

  <div class="mt-8 flex items-center justify-center gap-4">
    <%= link_to explore_path, class: "inline-block rounded-xl bg-brew-800 dark:bg-brew-200 text-white dark:text-stone-900 font-semibold px-6 py-3 no-underline hover:bg-brew-700 dark:hover:bg-brew-300 transition" do %>
      Explore breweries
    <% end %>
    <% if native_app? %>
      <% unless user_signed_in? %>
        <%= link_to "Sign in", new_session_path, class: "inline-block rounded-xl border border-stone-300 dark:border-stone-600 font-semibold px-6 py-3 no-underline hover:bg-stone-50 dark:hover:bg-stone-800 transition" %>
      <% end %>
    <% else %>
      <a href="https://apps.apple.com/app/beervana-brewery-passport/id6744076325">
        <img src="https://tools.applemediaservices.com/api/badges/download-on-the-app-store/black/en-us?size=250x83" alt="Download on the App Store" class="h-12">
      </a>
    <% end %>
  </div>
</div>

<div class="mt-12 space-y-4">
  <div class="p-5 rounded-2xl bg-white dark:bg-stone-900 shadow-sm">
    <div class="flex items-start gap-4">
      <div class="mt-0.5 w-10 h-10 rounded-xl bg-brew-100 dark:bg-brew-900 flex items-center justify-center shrink-0">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-brew-700 dark:text-brew-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
          <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
        </svg>
      </div>
      <div>
        <h2 class="font-semibold">Explore by neighborhood</h2>
        <p class="mt-1 text-sm text-stone-600 dark:text-stone-400">Browse Portland breweries organized by neighborhood. Check hours, happy hour specials, and amenities before you go.</p>
      </div>
    </div>
  </div>

  <div class="p-5 rounded-2xl bg-white dark:bg-stone-900 shadow-sm">
    <div class="flex items-start gap-4">
      <div class="mt-0.5 w-10 h-10 rounded-xl bg-brew-100 dark:bg-brew-900 flex items-center justify-center shrink-0">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-brew-700 dark:text-brew-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
      </div>
      <div>
        <h2 class="font-semibold">Stamp your passport</h2>
        <p class="mt-1 text-sm text-stone-600 dark:text-stone-400">Track every brewery you visit. Watch your passport fill up as you explore the city's craft beer scene.</p>
      </div>
    </div>
  </div>

  <div class="p-5 rounded-2xl bg-white dark:bg-stone-900 shadow-sm">
    <div class="flex items-start gap-4">
      <div class="mt-0.5 w-10 h-10 rounded-xl bg-brew-100 dark:bg-brew-900 flex items-center justify-center shrink-0">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-brew-700 dark:text-brew-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17.593 3.322c1.1.128 1.907 1.077 1.907 2.185V21L12 17.25 4.5 21V5.507c0-1.108.806-2.057 1.907-2.185a48.507 48.507 0 0 1 11.186 0Z" />
        </svg>
      </div>
      <div>
        <h2 class="font-semibold">Build your list</h2>
        <p class="mt-1 text-sm text-stone-600 dark:text-stone-400">Bookmark the breweries you want to visit. Check outdoor seating, dog-friendliness, kid-friendliness, and wifi at a glance.</p>
      </div>
    </div>
  </div>
</div>
