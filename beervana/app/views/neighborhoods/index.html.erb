<% content_for :title, "Explore" %>

<% if native_app? && !user_signed_in? %>
  <div class="mt-4 flex items-center justify-between p-4 rounded-2xl bg-white dark:bg-stone-900 shadow-sm">
    <p class="text-sm text-stone-600 dark:text-stone-400">Sign in to track your visits.</p>
    <%= link_to "Sign in", new_session_path, class: "rounded-xl bg-brew-800 dark:bg-brew-200 text-white dark:text-stone-900 font-semibold px-5 py-2.5 text-sm no-underline shrink-0 hover:bg-brew-700 dark:hover:bg-brew-300 transition" %>
  </div>
<% end %>

<div class="mt-4">
  <% unless native_app? %>
    <h1 class="text-2xl font-bold">Explore</h1>
  <% end %>

  <div class="mt-4 space-y-3">
    <%= link_to breweries_path, class: "flex items-center justify-between p-4 rounded-2xl bg-white dark:bg-stone-900 shadow-sm no-underline" do %>
      <div>
        <h2 class="font-semibold">View all</h2>
        <p class="text-sm text-stone-500 dark:text-stone-400 mt-0.5">
          <%= pluralize(@brewery_count, "brewery", "breweries") %>
        </p>
      </div>
      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-stone-400 dark:text-stone-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
      </svg>
    <% end %>

    <% @neighborhoods.sort_by(&:name).each do |neighborhood| %>
      <%= link_to neighborhood_path(neighborhood), class: "block rounded-2xl bg-white dark:bg-stone-900 shadow-sm no-underline overflow-hidden" do %>
        <% if neighborhood.map_light.attached? %>
          <%= image_tag neighborhood.map_light, class: "w-full aspect-[8/3] object-cover bg-stone-100 dark:bg-stone-800 shimmer dark:hidden", alt: "Map of #{neighborhood.name}" %>
          <%= image_tag neighborhood.map_dark, class: "w-full aspect-[8/3] object-cover bg-stone-100 dark:bg-stone-800 shimmer hidden dark:block", alt: "Map of #{neighborhood.name}" %>
        <% end %>
        <div class="flex items-center justify-between p-4">
          <div>
            <h2 class="font-semibold"><%= neighborhood.name %></h2>
            <p class="text-sm text-stone-500 dark:text-stone-400 mt-0.5">
              <%= pluralize(neighborhood.breweries.size, "brewery", "breweries") %>
            </p>
          </div>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-stone-400 dark:text-stone-600 shrink-0 ml-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
          </svg>
        </div>
      <% end %>
    <% end %>
  </div>
</div>
