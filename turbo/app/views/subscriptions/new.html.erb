<%= render "shared/header", title: "Upgrade" %>

<%= turbo_stream_from "purchasekit_customer_#{current_user.id}" %>

<div class="container text-center pt-3 pb-5">
  <i class="bi bi-bookmark-star fs-1 text-primary"></i>
  <h2 class="mt-3 fw-bold">Save unlimited links</h2>
  <p class="text-body-secondary mt-2 mb-4 px-4">
    You've reached the free limit of <%= SubscriptionGating::FREE_LINK_LIMIT %> links.
    Upgrade to save as many as you'd like.
  </p>

  <%= purchasekit_paywall customer_id: current_user.id, success_path: new_link_path do |paywall| %>
    <div class="row g-3 justify-content-center">
      <div class="col-6">
        <%= paywall.plan_option product: @annual, selected: true, input_class: "visually-hidden", class: "plan-card card p-3 h-100 text-start position-relative" do %>
          <span class="badge bg-primary position-absolute top-0 start-0 translate-middle-y ms-2">Best value</span>
          <i class="plan-check-off bi bi-circle position-absolute top-0 end-0 mt-2 me-2 text-muted"></i>
          <i class="plan-check-on bi bi-check-circle-fill position-absolute top-0 end-0 mt-2 me-2 text-primary"></i>
          <div class="fw-semibold">Annual</div>
          <div class="fs-5 fw-bold">
            <%= paywall.price do %>
              <div class="spinner-border spinner-border-sm" role="status">
                <span class="visually-hidden">Loading...</span>
              </div>
            <% end %>
            <span class="fs-6 fw-normal text-muted">/yr</span>
          </div>
          <small class="text-muted mt-1">Billed yearly</small>
        <% end %>
      </div>

      <div class="col-6">
        <%= paywall.plan_option product: @monthly, input_class: "visually-hidden", class: "plan-card card p-3 h-100 text-start position-relative" do %>
          <i class="plan-check-off bi bi-circle position-absolute top-0 end-0 mt-2 me-2 text-muted"></i>
          <i class="plan-check-on bi bi-check-circle-fill position-absolute top-0 end-0 mt-2 me-2 text-primary"></i>
          <div class="fw-semibold">Monthly</div>
          <div class="fs-5 fw-bold">
            <%= paywall.price do %>
              <div class="spinner-border spinner-border-sm" role="status">
                <span class="visually-hidden">Loading...</span>
              </div>
            <% end %>
            <span class="fs-6 fw-normal text-muted">/mo</span>
          </div>
          <small class="text-muted mt-1">Billed monthly</small>
        <% end %>
      </div>
    </div>

    <%= paywall.submit "Subscribe", class: "btn btn-primary btn-lg w-100 rounded-pill mt-4" %>
  <% end %>
</div>
